# SamaBank — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs si nécessaire
#
# Ces valeurs sont les DÉFAUTS utilisés par Spring Boot si les variables
# ne sont pas définies (syntaxe ${VAR:valeur_defaut} dans application.properties).
# Elles correspondent exactement à la configuration du conteneur Docker.

# ─── PostgreSQL (conteneur samabank-postgres) ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=samabank
DB_PASSWORD=samabank2025

# ─── Mailpit (conteneur samabank-mailpit) ──────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=1025
